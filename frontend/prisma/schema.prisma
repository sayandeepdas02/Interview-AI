generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  company   String?
  password  String
  createdAt DateTime @default(now())
  jobs      Job[]
}

model Job {
  id              String        @id @default(uuid())
  title           String
  description     String?
  roleType        String?       // Frontend, Backend, Full Stack
  experienceLevel String?       // Junior, Mid-Level, Senior
  location        String?
  status          String        @default("draft") // draft, published
  shareableLink   String?       @unique
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  testEnabled     Boolean       @default(false)
  testDuration    Int?          // in minutes
  passingScore    Int?          // percentage
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  questions       Question[]
  customFields    CustomField[]
  candidates      Candidate[]
}

model Question {
  id            String @id @default(uuid())
  jobId         String
  job           Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String // A, B, C, or D
  timeLimit     Int    @default(30) // seconds
  order         Int    @default(0)
}

model CustomField {
  id        String  @id @default(uuid())
  jobId     String
  job       Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  fieldName String
  fieldType String  // text, number, dropdown, checkbox
  required  Boolean @default(false)
  options   String? // JSON string for dropdown options
}

model Candidate {
  id              String   @id @default(uuid())
  jobId           String
  job             Job      @relation(fields: [jobId], references: [id])
  name            String
  email           String
  resumeUrl       String?
  currentCTC      Float?
  expectedCTC     Float?
  customFields    Json?    // Store custom field responses
  parsedResume    Json?    // Store parsed resume data
  testScore       Float?
  testPassed      Boolean?
  createdAt       DateTime @default(now())
  answers         Answer[]
}

model Answer {
  id             String    @id @default(uuid())
  candidateId    String
  candidate      Candidate @relation(fields: [candidateId], references: [id])
  questionId     String
  selectedAnswer String    // A, B, C, or D
  isCorrect      Boolean
  timeTaken      Int       // seconds
  createdAt      DateTime  @default(now())
}
